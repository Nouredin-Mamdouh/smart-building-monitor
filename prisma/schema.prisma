generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  NORMAL
  WARNING
  CRITICAL
}

enum OccupancyStatus {
  OCCUPIED
  VACANT
}

enum SensorType {
  TEMPERATURE
  OCCUPANCY
  ENERGY
}

enum SensorStatus {
  OK
  WARNING
  CRITICAL
  OFFLINE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum AlertStatus {
  ACTIVE
  RESOLVED
}

enum AlertSource {
  MANUAL
  SYSTEM
}

enum AlertRule {
  ROOM_TEMPERATURE
  ROOM_ENERGY
  SENSOR_TEMPERATURE
  SENSOR_ENERGY
  SENSOR_STATUS
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  passwordHash    String
  role            UserRole  @default(OPERATOR)
  isActive        Boolean   @default(true)
  deactivatedAt   DateTime?
  deactivatedById String?
  passwordUpdatedAt DateTime @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  deactivatedBy     User?   @relation("UserDeactivatedBy", fields: [deactivatedById], references: [id], onDelete: SetNull)
  deactivatedUsers  User[]  @relation("UserDeactivatedBy")
  acknowledgedAlerts Alert[] @relation("AlertAcknowledgedBy")
  resolvedAlerts     Alert[] @relation("AlertResolvedBy")
}

model Room {
  id                String           @id @default(uuid())
  name              String
  floor             Int              @default(1)
  svgId             String           @unique
  temperature       Float
  occupancyStatus   OccupancyStatus
  energyConsumption Float
  status            RoomStatus       @default(NORMAL)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  sensors           Sensor[]
  alerts            Alert[]
}

model Sensor {
  id         String       @id @default(uuid())
  name       String
  type       SensorType
  value      Float
  unit       String
  status     SensorStatus @default(OK)
  roomId     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  room       Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  alerts     Alert[]
}

model Alert {
  id               String        @id @default(uuid())
  message          String
  severity         AlertSeverity
  status           AlertStatus   @default(ACTIVE)
  source           AlertSource   @default(MANUAL)
  systemKey        String?
  systemRule       AlertRule?
  roomId           String
  sensorId         String?
  acknowledgedAt   DateTime?
  acknowledgedById String?
  resolvedAt       DateTime?
  resolvedById     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  room             Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sensor           Sensor?       @relation(fields: [sensorId], references: [id], onDelete: SetNull)
  acknowledgedBy   User?         @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)
  resolvedBy       User?         @relation("AlertResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([source, status, systemKey])
}
